{
  "meta": {
    "lastTouchedVersion": "2026.3.11"
  },
  "env": {
    "shellEnv": { "enabled": true }
  },
  "auth": {
    "profiles": {
      "deepseek:default": {
        "provider": "deepseek",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "custom-api-openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "<YOUR_OPENROUTER_API_KEY>",
        "api": "openai-completions",
        "models": [
          {
            "id": "bytedance-seed/seed-2.0-lite",
            "name": "Seed 2.0 Lite (Vision)",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 262144,
            "maxTokens": 16384
          }
        ]
      },
      "custom-api-deepseek-com": {
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "<YOUR_DEEPSEEK_API_KEY>",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek-V3 Chat",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek-R1 Reasoner",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "custom-api-openrouter/bytedance-seed/seed-2.0-lite"
      },
      "compaction": { "mode": "safeguard" }
    }
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave",
        "apiKey": "<YOUR_BRAVE_SEARCH_API_KEY>"
      }
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "accounts": {
        "default": {
          "appId": "<YOUR_FEISHU_APP_ID>",
          "appSecret": "<YOUR_FEISHU_APP_SECRET>",
          "botName": "CytoClaw",
          "dmPolicy": "open",
          "allowFrom": ["*"],
          "groupPolicy": "open"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "<GENERATE_A_RANDOM_TOKEN>"
    }
  },
  "skills": {
    "install": { "nodeManager": "npm" }
  },
  "plugins": {
    "entries": {
      "feishu": { "enabled": true }
    }
  }
}
